{
  "name": "obsidian-plugin-cue",
  "version": "1.0.0",
  "description": "Obsidian plugin for CUE language — syntax highlighting, validation, and preview",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "cue",
    "cuelang"
  ],
  "author": "dalsoop",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typia/unplugin": "^12.0.1",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "obsidian": "latest",
    "ts-patch": "^3.3.0",
    "typescript": "~5.7.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "tslib": "^2.8.1",
    "typia": "^12.0.1"
  }
}
