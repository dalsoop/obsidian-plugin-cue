{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "plugins": [
      { "transform": "typia/lib/transform" }
    ],
    "lib": ["DOM", "ES2020"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
